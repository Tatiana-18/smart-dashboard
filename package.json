{
  "name": "smart-dashboard",
  "version": "1.0.0",
  "description": "PWA приложение для продуктивности с Supabase backend",
  "type": "module",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "node --watch server/server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "jest --watch",
    "lint": "eslint public/src --ext .js",
    "lint:fix": "eslint public/src --ext .js --fix",
    "serve:frontend": "npx http-server public -p 3000"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "keywords": ["pwa", "dashboard", "productivity", "supabase"],
  "author": "Student",
  "license": "MIT"
}
